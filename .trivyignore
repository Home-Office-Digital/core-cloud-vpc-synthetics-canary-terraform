# ======================================================================
# .trivyignore - AWS Terraform ignore list for Trivy IaC scans
# ======================================================================
# Each ID (AVD-AWS-xxxx) corresponds to a specific AWS misconfiguration
# rule detected by Trivy (based on Aqua's tfsec/Trivy policies).
# Add/remove entries as needed — and always document the reason.
# ======================================================================

# ---------------------------
# S3
# ---------------------------

# Allow S3 buckets without versioning (handled by bucket lifecycle rules)
AVD-AWS-0089

# Allow public-read ACLs on specific dev/test buckets
AVD-AWS-0088

# Ignore S3 buckets without logging (logging handled externally)
AVD-AWS-0085

# ---------------------------
# IAM
# ---------------------------

# Ignore wildcard actions in IAM policies for managed service roles
AVD-AWS-0057

# Ignore IAM roles without explicit permissions boundary (managed by org SCPs)
AVD-AWS-0054

# ---------------------------
# CloudWatch / Logging
# ---------------------------

# Ignore log groups missing retention policy (set dynamically in modules)
AVD-AWS-0178

# Ignore CloudTrail not multi-region (we run regional trails)
AVD-AWS-0015

# ---------------------------
# EC2 / Security Groups
# ---------------------------

# Allow 0.0.0.0/0 ingress for specific bastion/dev instances
AVD-AWS-0104

# Ignore Security Group without description (not relevant for generated SGs)
AVD-AWS-0107

# ---------------------------
# KMS / Encryption
# ---------------------------

# Ignore resources without explicit KMS key (encryption handled by service defaults)
AVD-AWS-0090

# ---------------------------
# EBS / RDS / ECR
# ---------------------------

# Ignore EBS volumes without encryption (non-prod env)
AVD-AWS-0121

# Ignore RDS instance without storage encryption (handled by parameter group)
AVD-AWS-0132

# Ignore ECR repositories without image scanning (handled by pipeline)
AVD-AWS-0134

# ======================================================================
# END OF FILE
# ======================================================================